# ==========================================
# ax-builder 환경 변수
# ==========================================

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_ROOT_PASSWORD=axbuilder_dev_password
DB_NAME=ai_builder

# Google OAuth
# 발급 방법:
#   1. https://console.cloud.google.com 접속
#   2. API 및 서비스 → 사용자 인증 정보
#   3. OAuth 2.0 클라이언트 ID 만들기 (웹 애플리케이션)
#   4. 승인된 리디렉션 URI에 아래 URL 추가:
#      http://localhost:4000/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# 허용 이메일 도메인 (이 도메인의 Google 계정만 로그인 가능)
ALLOWED_EMAIL_DOMAIN=cv-3.com

# JWT 인증
JWT_SECRET=change_this_to_random_string

# Gemini API (Discovery Agent)
# 발급: https://aistudio.google.com/ → API 키 발급
GEMINI_API_KEY=AIza...

# Hermes Agent (빌드 파이프라인)
# setup.sh가 자동으로 감지하여 아래 값을 채웁니다.
# 수동 설정: hermes 설치 후 ~/.hermes/hermes-agent/venv/bin/python3 경로 입력
HERMES_PYTHON_PATH=
OPENROUTER_API_KEY=sk-or-...

# 서버 포트
BACKEND_PORT=4000
FRONTEND_PORT=5173

# 프로젝트 포트 범위
PROJECT_PORT_RANGE_START=3000
PROJECT_PORT_RANGE_END=3999
