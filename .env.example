# ==========================================
# ax-builder 환경 변수
# ==========================================

# Database (SQLite)
# 기본 경로: ./data/ax-builder.db (자동 생성됨)
# DB_PATH=/absolute/path/to/ax-builder.db

# Google OAuth
# 발급 방법:
#   1. https://console.cloud.google.com 접속
#   2. API 및 서비스 → 사용자 인증 정보
#   3. OAuth 2.0 클라이언트 ID 만들기 (웹 애플리케이션)
#   4. 승인된 리디렉션 URI에 아래 URL 추가:
#      http://localhost:3123/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3123/api/auth/google/callback

# 허용 이메일 도메인 (이 도메인의 Google 계정만 로그인 가능)
ALLOWED_EMAIL_DOMAIN=cv-3.com

# JWT 인증
JWT_SECRET=change_this_to_random_string

# OpenRouter API (기획 채팅 + Hermes 오케스트레이터 공용)
# 발급: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# 기획 채팅 모델 (기본: Gemma 4 31B — 심층 분석, 저비용)
# CHAT_MODEL=google/gemma-4-31b-it

# Hermes Agent (빌드 오케스트레이터)
# 기본: Qwen 3.5 35B — 판단/지시만, 코딩은 Claude Code CLI
# HERMES_MODEL=qwen/qwen3.5-35b-a3b
HERMES_PYTHON_PATH=

# 서버 포트
BACKEND_PORT=3123
FRONTEND_PORT=5173

# 프로젝트 포트 범위
PROJECT_PORT_RANGE_START=3000
PROJECT_PORT_RANGE_END=3999
