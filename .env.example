# ==========================================
# ax-builder 환경 변수
# ==========================================

# Database (SQLite)
# 기본 경로: ./data/ax-builder.db (자동 생성됨)
# DB_PATH=/absolute/path/to/ax-builder.db

# Google OAuth
# 발급 방법:
#   1. https://console.cloud.google.com 접속
#   2. API 및 서비스 → 사용자 인증 정보
#   3. OAuth 2.0 클라이언트 ID 만들기 (웹 애플리케이션)
#   4. 승인된 리디렉션 URI에 아래 URL 추가:
#      http://localhost:3123/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# 허용 이메일 도메인 (이 도메인의 Google 계정은 즉시 로그인 가능)
# 비워두면 모든 신규 사용자가 사용 신청서를 거침
ALLOWED_EMAIL_DOMAIN=cv-3.com

# 제품 주인 이메일 (사용 신청 승인 요청 수신)
OWNER_EMAIL=admin@cv-3.com

# Gmail SMTP (사용 신청/승인 메일 발송)
# Gmail 앱 비밀번호 발급: Google 계정 → 보안 → 2단계 인증 → 앱 비밀번호
GMAIL_USER=noreply@example.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# JWT 인증
JWT_SECRET=change_this_to_random_string

# OpenRouter API (기획 채팅 + Hermes 오케스트레이터 공용)
# 발급: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# 기획 채팅 모델 (기본: Gemini 3 Flash Preview)
# CHAT_MODEL=google/gemini-3-flash-preview

# Hermes Agent (빌드 오케스트레이터) — Gemini 3 Flash Preview
# 코딩은 Claude Code CLI(정액제)가 수행
# HERMES_MODEL=google/gemini-3-flash-preview
HERMES_PYTHON_PATH=

# 서버
BACKEND_PORT=4000
FRONTEND_PORT=3123
# OAuth 리다이렉트 등에서 사용하는 프론트엔드 URL
FRONTEND_URL=http://localhost:3123
# 도메인 사용 시: FRONTEND_URL=https://hackathon.acaxiaa.store

# 프로젝트 포트 범위
PROJECT_PORT_RANGE_START=3000
PROJECT_PORT_RANGE_END=3999

# ------------------------------------------
# AI Gateway (ADR 0003 / Phase 6)
# 생성된 앱이 AX_AI_BASE_URL + AX_AI_TOKEN으로 호출하는 게이트웨이.
# orchestrator가 직접 `/api/ai/v1/*` 엔드포인트를 제공한다.
# ------------------------------------------

# 생성 앱(Docker 컨테이너) 쪽에 AX_AI_BASE_URL로 주입되는 값.
# Docker Desktop(mac): http://host.docker.internal:4000/api/ai/v1
# 외부 IP: http://221.150.9.241:4000/api/ai/v1
AI_GATEWAY_BASE_URL=http://host.docker.internal:4000/api/ai/v1

# 업스트림 LLM provider (OpenAI 호환 엔드포인트).
# 기본: Gemini OpenAI-compat. 다른 provider 쓰려면 교체.
AI_GATEWAY_UPSTREAM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# 업스트림에 전달할 API 키. 미설정 시 GEMINI_API_KEY로 폴백.
# AI_GATEWAY_UPSTREAM_API_KEY=AIzaSy...

# Gemini API 키 — OpenRouter 외에 Gemini 직접 사용하거나 Gateway 업스트림용
GEMINI_API_KEY=
